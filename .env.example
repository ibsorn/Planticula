# =============================================================================
# Planticula — Variables de entorno
# =============================================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
#
# Cada función de IA tiene sus propias claves (prefijo específico).
# Si una función no tiene claves propias se usa el bloque OPENROUTER_* como
# fallback. Ningún valor está hardcodeado en el código — todo debe declararse
# aquí explícitamente.
#
# Proveedores soportados (cualquiera con API compatible con OpenAI):
#   OpenRouter  → https://openrouter.ai/api/v1
#   HuggingFace → https://api-inference.huggingface.co/v1
#   OpenAI      → https://api.openai.com/v1
#   Groq        → https://api.groq.com/openai/v1
#   Ollama      → http://localhost:11434/v1  (modelos locales)
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_ANON_KEY=<anon-key>


# =============================================================================
# IA — FALLBACK COMPARTIDO
# =============================================================================
# Se usa cuando una función no tiene claves propias (PLANT_ID_*, SOIL_AI_*, etc.)
# Las tres claves son obligatorias si no defines claves por función.

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-vl-8b-instruct


# =============================================================================
# IA — IDENTIFICACIÓN DE PLANTAS  (/plants/identify)
# =============================================================================
# Descomenta y rellena para usar un proveedor distinto al fallback.
#
# PLANT_ID_API_KEY=
# PLANT_ID_BASE_URL=
# PLANT_ID_MODEL=
#
# Ejemplo HuggingFace:
# PLANT_ID_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx
# PLANT_ID_BASE_URL=https://api-inference.huggingface.co/v1
# PLANT_ID_MODEL=meta-llama/Llama-3.2-11B-Vision-Instruct


# =============================================================================
# IA — ANÁLISIS DE SUSTRATO  (/soil-analysis)
# =============================================================================
# Descomenta y rellena para usar un proveedor distinto al fallback.
#
# SOIL_AI_API_KEY=
# SOIL_AI_BASE_URL=
# SOIL_AI_MODEL=
#
# Ejemplo HuggingFace:
# SOIL_AI_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx
# SOIL_AI_BASE_URL=https://api-inference.huggingface.co/v1
# SOIL_AI_MODEL=Qwen/Qwen2.5-VL-7B-Instruct


# =============================================================================
# IA — DIAGNÓSTICO DE ENFERMEDADES  (/plant-disease)
# =============================================================================
# Descomenta y rellena para usar un proveedor distinto al fallback.
#
# DISEASE_AI_API_KEY=
# DISEASE_AI_BASE_URL=
# DISEASE_AI_MODEL=
#
# Ejemplo HuggingFace:
# DISEASE_AI_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx
# DISEASE_AI_BASE_URL=https://api-inference.huggingface.co/v1
# DISEASE_AI_MODEL=meta-llama/Llama-3.2-11B-Vision-Instruct


# =============================================================================
# IA - IDENTIFICACION DE PLANTAS V2  (/plant-identification)
# =============================================================================
# Funcion nueva: identifica la especie, cuidados, toxicidad y guarda historial.
# Descomenta y rellena para usar un proveedor distinto al fallback.
#
# PLANT_ID_V2_API_KEY=
# PLANT_ID_V2_BASE_URL=
# PLANT_ID_V2_MODEL=
#
# Ejemplo OpenRouter (recomendado para vision):
# PLANT_ID_V2_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
# PLANT_ID_V2_BASE_URL=https://openrouter.ai/api/v1
# PLANT_ID_V2_MODEL=google/gemini-flash-1.5


# =============================================================================
# IA - IDENTIFICACION DE SEMILLAS  (/seed-identification)
# =============================================================================
# Funcion nueva: identifica semillas, germinacion y tiempo de siembra.
# Descomenta y rellena para usar un proveedor distinto al fallback.
#
# SEED_ID_API_KEY=
# SEED_ID_BASE_URL=
# SEED_ID_MODEL=
#
# Ejemplo OpenRouter (recomendado para vision):
# SEED_ID_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
# SEED_ID_BASE_URL=https://openrouter.ai/api/v1
# SEED_ID_MODEL=qwen/qwen3-vl-8b-instruct
