# =============================================================================
# Planticula — Variables de entorno
# =============================================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
#
# En PRODUCCIÓN: solo necesitas SUPABASE_URL y SUPABASE_ANON_KEY.
# Las claves de IA viven en Supabase Edge Functions (supabase secrets set).
#
# En DESARROLLO (sin Edge Functions desplegadas): puedes configurar
# OPENROUTER_* para que la app haga llamadas directas a la IA.
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE (OBLIGATORIO)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_ANON_KEY=<anon-key>


# =============================================================================
# IA — DESARROLLO (OPCIONAL)
# =============================================================================
# Solo necesario si las Edge Functions NO están desplegadas.
# En producción, las claves se configuran con:
#   supabase secrets set OPENROUTER_API_KEY=sk-or-v1-xxx
#   supabase secrets set OPENROUTER_MODEL=qwen/qwen3-vl-8b-instruct
#   supabase secrets set PLANTNET_API_KEY=xxx
#
# Descomenta para usar llamadas directas en desarrollo:

# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=qwen/qwen3-vl-8b-instruct


# =============================================================================
# IA — CLAVES POR FUNCIÓN (OPCIONAL, SOLO DESARROLLO)
# =============================================================================
# Si quieres usar un proveedor distinto para una función específica
# (sin Edge Functions), descomenta y rellena:

# PLANT_ID_API_KEY=
# PLANT_ID_BASE_URL=
# PLANT_ID_MODEL=
#
# SOIL_AI_API_KEY=
# SOIL_AI_BASE_URL=
# SOIL_AI_MODEL=
#
# DISEASE_AI_API_KEY=
# DISEASE_AI_BASE_URL=
# DISEASE_AI_MODEL=
#
# PLANT_ID_V2_API_KEY=
# PLANT_ID_V2_BASE_URL=
# PLANT_ID_V2_MODEL=
#
# SEED_ID_API_KEY=
# SEED_ID_BASE_URL=
# SEED_ID_MODEL=
